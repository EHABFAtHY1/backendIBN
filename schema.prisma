// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

model User {
  id            String  @id
  userName      String
  email         String? @unique
  passwordHash  String
  role          Role    @default(user)
  tel           String?
  photo         String?
  yearsOfExp    Int?
  descriptionAr String? @db.Text
  descriptionEn String? @db.Text

  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)

  @@map("sessions")
}

model Project {
  id String @id @default(cuid())

  titleAr String
  titleEn String

  locationAr String
  locationEn String

  descriptionAr String @db.Text
  descriptionEn String @db.Text

  fullDescriptionAr String @db.Text
  fullDescriptionEn String @db.Text

  durationAr String
  durationEn String

  teamAr String
  teamEn String

  workersCount   Int?
  engineersCount Int?
  injuredCount   Int?

  actualDurationAr String?
  actualDurationEn String?

  area   String
  status String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  techStack String[]
  gallery   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Category {
  id String @id @default(cuid())

  titleAr String
  titleEn String

  descriptionAr String @db.Text
  descriptionEn String @db.Text

  color String

  countAr String
  countEn String

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model QualityStandard {
  id String @id @default(cuid())

  titleAr       String
  titleEn       String
  descriptionAr String @db.Text
  descriptionEn String @db.Text
  icon          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quality_standards")
}

model Service {
  id String @id @default(cuid())

  titleAr       String
  titleEn       String
  descriptionAr String @db.Text
  descriptionEn String @db.Text

  fullDescriptionAr String? @db.Text
  fullDescriptionEn String? @db.Text

  icon     String
  gradient String

  areaAr String?
  areaEn String?

  statusAr String?
  statusEn String?

  teamAr String?
  teamEn String?

  gallery  String[]
  features String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("services")
}

model Department {
  id String @id @default(cuid())

  titleAr String
  titleEn String
  icon    String

  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model Section {
  id String @id @default(cuid())

  titleAr String
  titleEn String
  icon    String

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sections")
}

model CompanySettings {
  id String @id @default(cuid())

  nameAr String
  nameEn String

  yearsExperience       String
  clientsCount          String
  projectsCount         String
  satisfiedClientsCount String
  successPercentage     String

  valuesAr String[]
  valuesEn String[]

  ourSeenAr String
  ourSeenEn String

  telephone  String
  email      String
  addressAr  String
  addressEn  String
  addressUrl String

  logo String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}
